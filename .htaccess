# LB Time Tracker — règles de sécurité web (Apache)
# Bloque l'accès direct aux fichiers sensibles et aux dossiers internes.
# Si le serveur utilise nginx (seul ou en proxy), voir CLAUDE.md pour les
# directives nginx équivalentes à ajouter dans Plesk.

Options -Indexes
ServerSignature Off

# Fichiers sensibles : configuration, htaccess lui-même, gitignore, env
<FilesMatch "^(config\.php|\.htaccess|\.gitignore|\.env|composer\..*)$">
    Require all denied
</FilesMatch>

# Documentation interne (README, CLAUDE, …)
<FilesMatch "\.md$">
    Require all denied
</FilesMatch>

# Logs ou backups éventuels
<FilesMatch "\.(log|bak|sql)$">
    Require all denied
</FilesMatch>

# URL rewrite + blocages dossiers internes
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Blocages dossiers internes (avant les rewrites de routage)
    RewriteRule ^(lib|views|data|scripts|backups|design_handoff_lbtt_redesign)(/|$) - [F,L]
    RewriteRule ^\.git(/|$) - [F,L]

    # Fichiers/dossiers réels (assets, robots.txt, etc.) → servis directement
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Routes SEO-friendly → index.php?action=X
    RewriteRule ^signup/invite/([A-Za-z0-9_-]+)/?$        index.php?action=signup&invite=$1       [L,QSA]
    RewriteRule ^verify-email/([A-Za-z0-9_-]+)/?$         index.php?action=verify_email&token=$1  [L,QSA]
    RewriteRule ^team/(\d+)/?$                            index.php?action=team&id=$1             [L,QSA]
    RewriteRule ^avatar/(\d+)\.jpg$                       index.php?action=avatar&id=$1           [L,QSA]
    RewriteRule ^api/entries/?$                           index.php?action=api_entries            [L,QSA]
    RewriteRule ^api/save-entry/?$                        index.php?action=api_save_entry         [L,QSA]
    RewriteRule ^(login|signup|logout|calendar|summary|projects|profile|users)/?$  index.php?action=$1  [L,QSA]

    # Racine → index.php (PHP gère : login si non-auth, sinon calendar)
    RewriteRule ^$                                        index.php                               [L]
</IfModule>

# Fichiers de cache / rate limit
<FilesMatch "^\.version_cache\.json$">
    Require all denied
</FilesMatch>
